{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Launch MyApi",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build",
            "program": "${workspaceFolder}/MyApi/bin/Debug/net10.0/MyApi",
            "args": [],
            "cwd": "${workspaceFolder}/MyApi",
            "stopAtEntry": false,
            "env": {
                "ASPNETCORE_ENVIRONMENT": "Development",
                "ASPNETCORE_URLS": "http://localhost:5017"
            }
        }
    ]
}